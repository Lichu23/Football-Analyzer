# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── Virtual environment ────────────────────────────────────────────────────────
venv/
.venv/
env/

# ── ML model weights (large — downloaded automatically on first run) ───────────
*.pt
*.pth
*.onnx
*.weights

# ── Video files (too large for git) ───────────────────────────────────────────
videos/*
!videos/.gitkeep

# ── Generated output (heatmaps, annotated videos, exports) ────────────────────
output/*
!output/.gitkeep

# ── Phase 6 — Backend (FastAPI, Celery, Redis) ────────────────────────────────
*.db
*.sqlite3
instance/
celerybeat-schedule
celerybeat.pid

# ── Phase 6 — Docker ──────────────────────────────────────────────────────────
.dockerignore

# ── Phase 6/8 — Environment variables & secrets ───────────────────────────────
.env
.env.*
!.env.example

# ── Phase 6 — AWS ─────────────────────────────────────────────────────────────
*.pem
.aws/

# ── Phase 7 — Frontend (Next.js / React) ──────────────────────────────────────
node_modules/
.next/
frontend/dist/
frontend/build/
.vercel/

# ── Phase 9 — Terraform (infrastructure as code) ──────────────────────────────
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
